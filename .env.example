# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Whisper
# Model sizes: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=small
# Device: cpu | cuda | auto  (use cpu on WSL unless you have CUDA set up)
WHISPER_DEVICE=cpu
# Quantisation: int8 (fastest on CPU) | float16 | float32
WHISPER_COMPUTE_TYPE=int8

# Hugging Face (required for pyannote diarization models)
# Get your free token at https://huggingface.co/settings/tokens
# Then accept the pyannote model license at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_hf_token_here

# Storage
DB_PATH=data/meetings.db
CHROMA_PATH=data/chroma
TRANSCRIPT_DIR=data/transcripts

# RAG
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4

# App
APP_HOST=0.0.0.0
APP_PORT=7860
DEBUG=false
